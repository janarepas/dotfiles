# Letöltési formátum: legjobb videó + legjobb hang
-f "bv*+ba/best"

# Fájlnevek sablonja
-o "~/Downloads/%(title)s.%(ext)s"

# Automatikus feliratletöltés (ha van)
--write-subs
--sub-lang "en.*"
--sub-format "srt"

# Ne kérjen interaktív inputot
--no-continue
--no-part
--no-overwrites

# Mini log a hibákhoz
--console-title
--no-warnings
--quiet

# Thumb képek mentése, ha van
--write-thumbnail

# Metadata beégetése (ha van mutagen/ffmpeg)
--embed-metadata
--embed-thumbnail

# Ha elérhető: 60fps, nagy bitráta, stb.
--merge-output-format "mp4"
